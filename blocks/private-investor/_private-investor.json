                    "label": "Element Type",
                    "description": "Choose the type of form element.",
                    "options": [
                        {
                            "name": "Text Input",
                            "value": "text_input"
                        },
                        {
                            "name": "Static Text",
                            "value": "static_text"
                        },
                        {
                            "name": "Submit Button",
                            "value": "submit"
                        }
                    ]
                },
                {
                    "component": "text",
                    "valueType": "string",
                    "name": "col1_name",
                    "label": "Field Name Attribute",
                    "description": "Dynamic variable name for form submission (e.g., 'first_name').",
                    "condition": {
                        "===": [
                            {
                                "var": "col1_select"
                            },
                            "text_input"
                        ]
                    }
                },
                {
                    "component": "text",
                    "valueType": "string",
                    "name": "col1_label",
                    "label": "Label / Content / Button Text",
                    "description": "Acts as the label for inputs, paragraph text for Static Text, or the label for the Submit button."
                    // No condition here, as all 3 element types require some form of text content.
                },
                {
                    "component": "text",
                    "valueType": "string",
                    "name": "col1_placeholder",
                    "label": "Input Placeholder",
                    "condition": {
                        "===": [
                            {
                                "var": "col1_select"
                            },
                            "text_input"
